{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/promotion-policy.schema.json",
  "title": "Promotion Policy",
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "min_reuse_score",
    "min_origin_value",
    "max_risk_score",
    "require_trace_record",
    "require_human_review",
    "default_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 3
    },
    "min_reuse_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "min_origin_value": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "max_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "require_trace_record": {
      "type": "boolean"
    },
    "require_human_review": {
      "type": "boolean"
    },
    "default_action": {
      "type": "string",
      "enum": [
        "discard",
        "compress",
        "quarantine",
        "promote_candidate"
      ]
    },
    "allowed_destinations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "core_memory",
          "core_datacenter",
          "origin_registry",
          "audit_archive",
          "royalty_record"
        ]
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
