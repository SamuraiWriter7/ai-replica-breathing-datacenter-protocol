{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/staging-policy.schema.json",
  "title": "Staging Policy",
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "default_zone",
    "zones",
    "deduplication",
    "quarantine",
    "raw_input_handling",
    "promotion_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 3
    },
    "default_zone": {
      "type": "string",
      "enum": [
        "shadow_staging",
        "candidate_pool",
        "summary_cache",
        "quarantine"
      ]
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "zone_id",
          "purpose",
          "temporary",
          "max_retention_days"
        ],
        "properties": {
          "zone_id": {
            "type": "string",
            "enum": [
              "shadow_staging",
              "candidate_pool",
              "summary_cache",
              "quarantine",
              "discard_buffer"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "temporary": {
            "type": "boolean"
          },
          "max_retention_days": {
            "type": "integer",
            "minimum": 0
          },
          "requires_audit": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "deduplication": {
      "type": "object",
      "required": [
        "enabled",
        "method"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "method": {
          "type": "string",
          "enum": [
            "none",
            "hash",
            "semantic_similarity",
            "hash_and_semantic_similarity"
          ]
        },
        "similarity_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "quarantine": {
      "type": "object",
      "required": [
        "enabled",
        "risk_threshold",
        "human_review_required"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "risk_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "human_review_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "raw_input_handling": {
      "type": "object",
      "required": [
        "store_raw_input",
        "raw_retention_days",
        "compress_after_days"
      ],
      "properties": {
        "store_raw_input": {
          "type": "boolean"
        },
        "raw_retention_days": {
          "type": "integer",
          "minimum": 0
        },
        "compress_after_days": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "promotion_boundary": {
      "type": "object",
      "required": [
        "direct_core_write_allowed",
        "requires_promotion_policy",
        "requires_trace_record"
      ],
      "properties": {
        "direct_core_write_allowed": {
          "type": "boolean"
        },
        "requires_promotion_policy": {
          "type": "boolean"
        },
        "requires_trace_record": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
