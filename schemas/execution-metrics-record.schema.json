{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/execution-metrics-record.schema.json",
  "title": "Execution Metrics Record",
  "type": "object",
  "required": [
    "schema_version",
    "metrics_id",
    "created_at",
    "related_cycle_id",
    "measured_scope",
    "replicas",
    "token_usage",
    "execution",
    "energy_estimate",
    "outcome"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.5.0"
    },
    "metrics_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "related_cycle_id": {
      "type": "string",
      "minLength": 3
    },
    "coordination_id": {
      "type": "string"
    },
    "measured_scope": {
      "type": "string",
      "enum": [
        "single_replica",
        "breathing_cycle",
        "coordination_task",
        "repair_loop",
        "promotion_flow",
        "cluster"
      ]
    },
    "replicas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "replica_id",
          "role",
          "model_class"
        ],
        "properties": {
          "replica_id": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "enum": [
              "intake",
              "classifier",
              "compressor",
              "auditor",
              "generator",
              "repair",
              "orchestrator",
              "reviewer"
            ]
          },
          "model_class": {
            "type": "string",
            "enum": [
              "small",
              "medium",
              "large",
              "core",
              "external"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "token_usage": {
      "type": "object",
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "runtime_seconds",
        "core_model_activated",
        "repair_attempts",
        "handoff_count"
      ],
      "properties": {
        "runtime_seconds": {
          "type": "number",
          "minimum": 0
        },
        "core_model_activated": {
          "type": "boolean"
        },
        "repair_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "handoff_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "energy_estimate": {
      "type": "object",
      "required": [
        "measurement_mode",
        "estimated_energy_wh",
        "estimated_core_avoided",
        "estimated_savings_ratio"
      ],
      "properties": {
        "measurement_mode": {
          "type": "string",
          "enum": [
            "none",
            "estimated",
            "measured",
            "hybrid"
          ]
        },
        "estimated_energy_wh": {
          "type": "number",
          "minimum": 0
        },
        "estimated_core_avoided": {
          "type": "boolean"
        },
        "estimated_savings_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "outcome": {
      "type": "object",
      "required": [
        "status",
        "promotion_candidate",
        "records_discarded",
        "records_retained"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "completed_with_repair",
            "stopped_by_budget",
            "deferred_to_core",
            "discarded",
            "failed"
          ]
        },
        "promotion_candidate": {
          "type": "boolean"
        },
        "records_discarded": {
          "type": "integer",
          "minimum": 0
        },
        "records_retained": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
